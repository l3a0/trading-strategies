{
  // Pyright / Pylance configuration.
  //
  // typeCheckingMode is intentionally left unset so the five hand-authored
  // .py files are checked in pyright's default mode — identical to before
  // this file existed. CI passes those files explicitly
  // (`pyright cc_backtest.py ... test_cc_backtest.py`), and pyright always
  // analyzes explicitly-listed files regardless of the settings below.
  //
  // "ignore" suppresses diagnostics for the generated notebook even when
  // it's open in the editor. covered_call_backtest.ipynb is a build
  // artifact (like docs/figures/*.png): its real source is the tutorial
  // markdown, regenerated by make_notebook.py and drift-checked in CI. It
  // faithfully mirrors the tutorial's deliberately untyped, beginner-facing
  // teaching snippets (normal_pdf(x), the run_cc_overlay_day pseudo-handler
  // that is "illustrative, not a function in the codebase", etc.). The
  // fully typed production implementations live in cc_backtest.py, which is
  // what gets type-checked. Annotating the notebook copies would diverge it
  // from the tutorial and clutter the teaching code. Same rationale as the
  // .ipynb exclusion in ruff.toml.
  // The first three entries are pyright's built-in defaults — specifying
  // "exclude" replaces them, so they're restored here. ".venv" is listed
  // explicitly because Pylance's missingDefaultExcludes hint expects the
  // detected virtual-env path by name, even though "**/.*" already matches
  // it (and .ipynb_checkpoints, .git, .ruff_cache, .pytest_cache).
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/.*",
    ".venv",
    "covered_call_backtest.ipynb"
  ],
  "ignore": [
    "covered_call_backtest.ipynb"
  ]
}
